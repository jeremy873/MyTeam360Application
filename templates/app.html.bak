<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MyTeam360 — AI Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--bg-0:#09090b;--bg-1:#0c0c0f;--bg-2:#111114;--bg-3:#161619;--surface:#0f0f12;--s2:#141417;--s3:#19191d;--sh:#1c1c21;--border:#1e1e23;--bd:#151518;--bh:#27272e;--bf:#3b3bf0;--t0:#fafafa;--t1:#e4e4e8;--t2:#8e8e9a;--t3:#5c5c6a;--t4:#3a3a44;--accent:#4f46e5;--ah:#6366f1;--as:rgba(79,70,229,.08);--am:rgba(79,70,229,.14);--at:#a5b4fc;--green:#22c55e;--gs:rgba(34,197,94,.08);--gt:#86efac;--red:#ef4444;--rs:rgba(239,68,68,.08);--rt:#fca5a5;--orange:#f59e0b;--os:rgba(245,158,11,.08);--blue:#3b82f6;--bs:rgba(59,130,246,.08);--sw:220px;--th:48px;--font:'Inter',-apple-system,sans-serif;--mono:'JetBrains Mono',monospace;--tr:.15s ease}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
body{font-family:var(--font);background:var(--bg-0);color:var(--t1);height:100vh;overflow:hidden;font-size:13px;line-height:1.5;-webkit-font-smoothing:antialiased}
a{color:var(--at);text-decoration:none}button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit;font-size:inherit}input,textarea,select{font-family:inherit;font-size:13px;color:var(--t1)}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}::placeholder{color:var(--t4)}::selection{background:rgba(79,70,229,.3)}.hidden{display:none!important}
#auth-screen{display:flex;align-items:center;justify-content:center;height:100vh;background:var(--bg-0);position:fixed;inset:0;z-index:1000}
.auth-box{width:400px;background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:40px;box-shadow:0 16px 48px rgba(0,0,0,.6)}
.auth-logo{display:flex;align-items:center;gap:10px;justify-content:center;margin-bottom:28px}
.auth-logo .mark{width:36px;height:36px;background:linear-gradient(135deg,var(--accent),#818cf8);border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;color:#fff;font-family:var(--mono)}
.auth-logo .wordmark{font-weight:700;font-size:22px;letter-spacing:-.6px;color:var(--t0)}
.auth-subtitle{text-align:center;font-size:13px;color:var(--t3);margin-bottom:24px}
.auth-field{margin-bottom:16px}.auth-field label{display:block;font-size:12px;font-weight:500;color:var(--t2);margin-bottom:6px}
.auth-field input{width:100%;padding:10px 14px;background:var(--bg-2);border:1px solid var(--border);border-radius:6px;color:var(--t1);outline:none;transition:var(--tr)}
.auth-field input:focus{border-color:var(--bf);box-shadow:0 0 0 3px rgba(79,70,229,.12)}
.auth-btn{width:100%;padding:11px;background:var(--accent);color:#fff;border-radius:6px;font-weight:600;font-size:13px;margin-top:8px;transition:var(--tr)}.auth-btn:hover{background:var(--ah)}
.auth-error{color:var(--red);font-size:12px;text-align:center;margin-top:12px;min-height:18px}
.auth-switch{text-align:center;margin-top:20px;font-size:12px;color:var(--t3)}.auth-switch a{cursor:pointer;color:var(--at)}
#app{display:none;height:100vh}#app.active{display:flex}
.sidebar{width:var(--sw);background:var(--bg-1);border-right:1px solid var(--bd);display:flex;flex-direction:column;flex-shrink:0}
.sidebar-head{padding:14px 16px;display:flex;align-items:center;gap:9px;border-bottom:1px solid var(--bd);height:var(--th)}
.sidebar-head .mark{width:26px;height:26px;background:linear-gradient(135deg,var(--accent),#818cf8);border-radius:7px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:10px;color:#fff;font-family:var(--mono);flex-shrink:0}
.sidebar-head .brand{font-weight:700;font-size:15px;letter-spacing:-.4px;color:var(--t0)}
.nav-group{padding:16px 12px 4px}.nav-label{font-size:10px;font-weight:600;color:var(--t4);text-transform:uppercase;letter-spacing:1px;padding:0 8px;margin-bottom:4px}
.nav-item{display:flex;align-items:center;gap:10px;padding:8px 12px;margin:1px 0;border-radius:6px;color:var(--t2);font-size:12.5px;font-weight:500;cursor:pointer;transition:var(--tr);position:relative}
.nav-item:hover{background:var(--sh);color:var(--t1)}.nav-item.active{background:var(--am);color:var(--at);font-weight:600}
.nav-item svg{width:16px;height:16px;opacity:.45;flex-shrink:0}.nav-item.active svg{opacity:1}
.nav-badge{position:absolute;right:10px;background:var(--red);color:#fff;font-size:9px;font-weight:700;padding:1px 6px;border-radius:8px;min-width:18px;text-align:center;line-height:14px}
.sidebar-foot{margin-top:auto;padding:10px 12px;border-top:1px solid var(--bd)}
.user-card{display:flex;align-items:center;gap:10px;padding:8px;border-radius:6px;cursor:pointer;transition:var(--tr)}.user-card:hover{background:var(--sh)}
.user-av{width:32px;height:32px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
.user-info{flex:1;min-width:0}.user-name{font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--t1)}.user-role{font-size:10px;color:var(--t3);text-transform:capitalize}
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{height:var(--th);border-bottom:1px solid var(--bd);display:flex;align-items:center;padding:0 20px;gap:12px;flex-shrink:0;background:var(--bg-1)}
.topbar-title{font-weight:600;font-size:14px;letter-spacing:-.2px;color:var(--t0)}.topbar-spacer{flex:1}
.topbar-search{background:var(--bg-2);border:1px solid var(--border);border-radius:6px;padding:7px 12px;width:220px;font-size:12px;color:var(--t1);outline:none;transition:var(--tr)}
.topbar-search:focus{border-color:var(--bf);width:280px}
.content{flex:1;overflow-y:auto;padding:24px}.screen{display:none;animation:fadeIn .15s ease}.screen.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.btn{padding:8px 16px;border-radius:6px;font-weight:500;font-size:12px;transition:var(--tr);display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
.btn-primary{background:var(--accent);color:#fff}.btn-primary:hover{background:var(--ah)}
.btn-secondary{background:var(--s3);color:var(--t2);border:1px solid var(--border)}.btn-secondary:hover{background:var(--sh);color:var(--t1)}
.btn-danger{background:var(--rs);color:var(--rt)}.btn-ghost{color:var(--t2)}.btn-ghost:hover{color:var(--t1);background:var(--sh)}
.btn-sm{padding:5px 10px;font-size:11px}.btn-xs{padding:3px 8px;font-size:10px}
.badge{font-size:10px;font-weight:600;padding:2px 8px;border-radius:10px;display:inline-flex}
.badge.owner{background:rgba(245,158,11,.12);color:#fbbf24}.badge.admin{background:rgba(79,70,229,.12);color:var(--at)}
.badge.member{background:var(--gs);color:var(--gt)}.badge.viewer{background:rgba(142,142,154,.1);color:var(--t2)}
.badge.active{background:var(--gs);color:var(--gt)}.badge.pending{background:var(--os);color:#fbbf24}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px 18px}
.stat-label{font-size:11px;color:var(--t3);font-weight:500;margin-bottom:6px}
.stat-val{font-size:24px;font-weight:700;font-family:var(--mono);letter-spacing:-.5px;color:var(--t0)}
.stat-sub{font-size:10px;color:var(--t4);margin-top:2px;font-family:var(--mono)}
.dash-grid{display:grid;grid-template-columns:1fr 340px;gap:14px}
.dash-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;overflow:hidden}
.dash-card-head{padding:12px 16px;font-size:12px;font-weight:600;border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between;color:var(--t0)}
.dash-card-body{padding:12px 16px}
.activity-item{display:flex;gap:10px;padding:8px 0;border-bottom:1px solid var(--bd);font-size:12px}.activity-item:last-child{border-bottom:none}
.activity-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;background:var(--bg-2)}
.activity-text{flex:1;color:var(--t2);line-height:1.4}.activity-text strong{color:var(--t1);font-weight:600}
.activity-time{font-size:10px;color:var(--t4);font-family:var(--mono);flex-shrink:0}
.section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.section-title{font-size:18px;font-weight:700;letter-spacing:-.3px;color:var(--t0)}
.section-sub{font-size:12px;color:var(--t3);margin-top:2px}
.grid{display:grid;gap:12px}.grid-3{grid-template-columns:repeat(auto-fill,minmax(280px,1fr))}
.filter-bar{display:flex;align-items:center;gap:6px;margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid var(--bd)}
.filter-btn{padding:5px 12px;border-radius:6px;font-size:11px;font-weight:500;color:var(--t3);background:transparent;transition:var(--tr)}
.filter-btn:hover{color:var(--t1);background:var(--sh)}.filter-btn.active{color:var(--at);background:var(--as);font-weight:600}
.screen-split{display:flex}.screen-sidebar{width:240px;border-right:1px solid var(--bd);flex-shrink:0;overflow-y:auto}.screen-main{flex:1;overflow-y:auto}
.chat-sidebar{background:var(--bg-1)}.chat-sidebar-head{padding:10px;display:flex;gap:8px;border-bottom:1px solid var(--bd)}
.chat-sidebar-head input{flex:1;padding:7px 10px;background:var(--bg-2);border:1px solid var(--border);border-radius:6px;font-size:12px;color:var(--t1);outline:none}
.conv-item{padding:10px 12px;cursor:pointer;border-bottom:1px solid var(--bd);transition:var(--tr)}.conv-item:hover{background:var(--sh)}
.conv-item.active{background:var(--as);border-left:2px solid var(--accent)}
.conv-item-name{font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:2px;color:var(--t1)}
.conv-item-meta{font-size:10px;color:var(--t4);display:flex;gap:8px}
.chat-area{display:flex;flex-direction:column;background:var(--bg-0)}
.chat-topbar{padding:0 16px;height:42px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--bd);background:var(--surface);flex-shrink:0}
.chat-topbar select{background:var(--bg-2);border:1px solid var(--border);border-radius:6px;padding:5px 8px;font-size:11px;color:var(--t1);outline:none}
.chat-messages{flex:1;overflow-y:auto;padding:16px 20px;display:flex;flex-direction:column;gap:12px}
.msg{max-width:72%;display:flex;flex-direction:column}.msg.user{align-self:flex-end}.msg.assistant{align-self:flex-start}
.msg-bubble{padding:10px 14px;border-radius:8px;font-size:13px;line-height:1.6}
.msg.user .msg-bubble{background:var(--accent);color:#fff;border-bottom-right-radius:4px}
.msg.assistant .msg-bubble{background:var(--s2);border:1px solid var(--border);color:var(--t1);border-bottom-left-radius:4px}
.msg-bubble pre{background:var(--bg-0);border:1px solid var(--border);border-radius:6px;padding:10px;margin:8px 0;overflow-x:auto;font-family:var(--mono);font-size:12px}
.msg-bubble code{font-family:var(--mono);font-size:12px}.msg-time{font-size:9px;color:var(--t4);margin-top:4px;padding:0 4px}.msg.user .msg-time{text-align:right}
.chat-empty-state{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--t3)}
.chat-empty-state .icon{font-size:32px;margin-bottom:8px;opacity:.5}.chat-empty-state .title{font-size:14px;font-weight:600;color:var(--t2)}
.chat-input-area{padding:12px 16px;border-top:1px solid var(--bd);background:var(--surface)}
.chat-input-row{display:flex;gap:8px;align-items:flex-end}
.chat-input-row textarea{flex:1;padding:10px 14px;background:var(--bg-2);border:1px solid var(--border);border-radius:8px;color:var(--t1);outline:none;resize:none;font-size:13px;line-height:1.5;max-height:150px;transition:var(--tr)}
.chat-input-row textarea:focus{border-color:var(--bf)}
.chat-send{width:38px;height:38px;border-radius:6px;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;transition:var(--tr);flex-shrink:0}
.chat-send:hover{background:var(--ah)}.chat-send:disabled{opacity:.4;pointer-events:none}
.chat-send svg{width:16px;height:16px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.typing-indicator{display:flex;gap:4px;padding:6px 0;align-items:center}
.typing-dot{width:6px;height:6px;background:var(--t4);border-radius:50%;animation:tb .6s ease infinite}
.typing-dot:nth-child(2){animation-delay:.15s}.typing-dot:nth-child(3){animation-delay:.3s}
@keyframes tb{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}
.agent-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px;cursor:pointer;transition:var(--tr)}
.agent-card:hover{border-color:var(--bh);box-shadow:0 1px 2px rgba(0,0,0,.4)}
.agent-card-head{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.agent-card-icon{width:38px;height:38px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.agent-card-name{font-size:13px;font-weight:600;color:var(--t0)}.agent-card-provider{font-size:10px;color:var(--t3);font-family:var(--mono)}
.agent-card-desc{font-size:12px;color:var(--t3);margin-bottom:12px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.5}
.agent-card-foot{display:flex;align-items:center;justify-content:space-between;font-size:10px;color:var(--t4)}
.wf-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px;cursor:pointer;transition:var(--tr)}.wf-card:hover{border-color:var(--bh)}
.wf-head{display:flex;align-items:center;gap:8px;margin-bottom:10px}.wf-icon{font-size:18px}.wf-name{font-weight:600;font-size:13px;flex:1;color:var(--t0)}
.wf-steps{display:flex;align-items:center;gap:4px;margin-bottom:10px;flex-wrap:wrap}
.wf-step{width:30px;height:30px;background:var(--s2);border:1px solid var(--border);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px}
.wf-arrow{color:var(--t4);font-size:11px}.wf-desc{font-size:12px;color:var(--t3);margin-bottom:10px}
.wf-foot{display:flex;gap:14px;font-size:10px;color:var(--t4)}
.kb-sidebar{background:var(--bg-1);padding:12px}
.folder-item{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:6px;cursor:pointer;font-size:12px;color:var(--t2);transition:var(--tr)}
.folder-item:hover{background:var(--sh);color:var(--t1)}.folder-item.active{background:var(--am);color:var(--at)}
.folder-item .count{margin-left:auto;font-size:10px;color:var(--t4);font-family:var(--mono)}
.kb-main{padding:16px}.kb-doc{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px;transition:var(--tr)}.kb-doc:hover{border-color:var(--bh)}
.kb-doc-head{display:flex;align-items:center;gap:8px;margin-bottom:4px}.kb-doc-icon{font-size:16px}
.kb-doc-name{font-size:12px;font-weight:600;flex:1;color:var(--t1)}
.kb-doc-del{color:var(--t4);cursor:pointer;font-size:14px;opacity:0;transition:var(--tr)}.kb-doc:hover .kb-doc-del{opacity:1}.kb-doc-del:hover{color:var(--red)}
.kb-doc-meta{font-size:10px;color:var(--t3);margin-top:2px}
.kb-doc-tags{display:flex;gap:4px;margin-top:8px;flex-wrap:wrap}
.kb-tag{font-size:9px;padding:2px 8px;background:var(--as);color:var(--at);border-radius:3px;font-weight:500}
.kb-upload{border:1px dashed var(--bh);border-radius:8px;padding:28px;text-align:center;color:var(--t3);margin-bottom:16px;cursor:pointer;transition:var(--tr)}
.kb-upload:hover{border-color:var(--accent);background:var(--as)}
.team-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px}
.team-head{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.team-av{width:36px;height:36px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
.team-name{font-size:13px;font-weight:600;color:var(--t0)}.team-email{font-size:10px;color:var(--t3)}
.team-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.team-stat{text-align:center;padding:8px;background:var(--bg-2);border-radius:6px}
.team-stat-label{font-size:9px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px}
.team-stat-val{font-size:16px;font-weight:700;font-family:var(--mono);color:var(--t0);margin-top:2px}
.budget-bar{height:4px;background:var(--bg-0);border-radius:2px;overflow:hidden}.budget-fill{height:100%;border-radius:2px;transition:.3s}
.approval-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:12px}
.approval-head{display:flex;align-items:center;gap:8px;margin-bottom:8px}.approval-icon{font-size:18px}
.approval-title{font-weight:600;font-size:13px;flex:1;color:var(--t0)}
.approval-preview{font-size:12px;color:var(--t3);background:var(--bg-2);border-radius:6px;padding:10px 12px;margin-bottom:10px;max-height:80px;overflow:hidden;border:1px solid var(--bd)}
.approval-meta{font-size:10px;color:var(--t4);margin-bottom:12px}.approval-actions{display:flex;gap:8px}
.integ-section{margin-bottom:28px}.integ-section h3{font-size:11px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:12px}
.integ-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px}
.integ-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px;display:flex;align-items:center;gap:12px;transition:var(--tr)}
.integ-card:hover{border-color:var(--bh)}.integ-icon{font-size:20px;flex-shrink:0}.integ-info{flex:1}
.integ-name{font-size:12px;font-weight:600;color:var(--t1)}.integ-status{font-size:10px;color:var(--t3);margin-top:1px}
.integ-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}.integ-dot.on{background:var(--green);box-shadow:0 0 6px rgba(34,197,94,.3)}.integ-dot.off{background:var(--t4)}
.settings-layout{display:grid;grid-template-columns:180px 1fr;gap:24px}
.settings-nav{display:flex;flex-direction:column;gap:2px}
.settings-nav-item{padding:8px 12px;border-radius:6px;font-size:12px;color:var(--t2);cursor:pointer;transition:var(--tr);font-weight:500}
.settings-nav-item:hover{background:var(--sh);color:var(--t1)}.settings-nav-item.active{color:var(--at);background:var(--as);font-weight:600}
.settings-section{margin-bottom:28px}.settings-section h3{font-size:15px;font-weight:700;color:var(--t0);margin-bottom:3px}
.settings-section>p{font-size:12px;color:var(--t3);margin-bottom:16px}
.setting-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--bd)}
.setting-label{font-size:13px;font-weight:500;color:var(--t1)}.setting-desc{font-size:11px;color:var(--t3);margin-top:1px}
.key-row{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--bd)}
.key-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}.key-name{font-size:12px;font-weight:600;width:120px;color:var(--t1)}
.key-mask{font-size:11px;color:var(--t3);font-family:var(--mono);flex:1}.key-action{font-size:11px;color:var(--at);cursor:pointer;font-weight:500}
.form-group{margin-bottom:14px}.form-group label{display:block;font-size:11px;font-weight:500;color:var(--t2);margin-bottom:5px;text-transform:uppercase;letter-spacing:.4px}
.form-input{width:100%;padding:9px 12px;background:var(--bg-2);border:1px solid var(--border);border-radius:6px;color:var(--t1);outline:none;transition:var(--tr)}
.form-input:focus{border-color:var(--bf);box-shadow:0 0 0 3px rgba(79,70,229,.1)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-check{display:flex;align-items:center;gap:8px;margin-bottom:10px;font-size:12px;color:var(--t2)}
.form-check input[type="checkbox"]{accent-color:var(--accent)}
.form-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:16px;padding-top:16px;border-top:1px solid var(--bd)}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(4px);z-index:900;display:none;align-items:center;justify-content:center}
.modal-overlay.active{display:flex}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;width:520px;max-height:85vh;overflow-y:auto;box-shadow:0 16px 48px rgba(0,0,0,.6)}
.modal-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.modal-title{font-size:16px;font-weight:700;color:var(--t0)}
.modal-close{width:28px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:6px;cursor:pointer;color:var(--t3);transition:var(--tr);font-size:16px}
.modal-close:hover{background:var(--sh);color:var(--t1)}
.toggle{width:36px;height:20px;background:var(--border);border-radius:10px;position:relative;cursor:pointer;transition:var(--tr);flex-shrink:0}
.toggle::after{content:'';position:absolute;top:2px;left:2px;width:16px;height:16px;background:#fff;border-radius:50%;transition:var(--tr)}
.toggle.on{background:var(--accent)}.toggle.on::after{left:18px}
.empty-state{text-align:center;padding:40px 20px}.empty-state .icon{font-size:32px;margin-bottom:8px;opacity:.4}
.empty-state .title{font-size:14px;font-weight:600;color:var(--t2);margin-bottom:4px}.empty-state .desc{font-size:12px;color:var(--t3)}
.dept-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px;transition:var(--tr)}.dept-card:hover{border-color:var(--bh)}
.dept-head{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.dept-icon{width:38px;height:38px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.dept-name{font-size:14px;font-weight:600;color:var(--t0)}.dept-meta{font-size:11px;color:var(--t3)}
.dept-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:10px}
.dept-stat{text-align:center;padding:6px;background:var(--bg-2);border-radius:6px}
.dept-stat-label{font-size:9px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px}
.dept-stat-val{font-size:14px;font-weight:700;font-family:var(--mono);color:var(--t0)}
.audit-row{display:flex;gap:12px;padding:10px 0;border-bottom:1px solid var(--bd);font-size:12px;align-items:center}
.audit-time{font-size:10px;color:var(--t4);font-family:var(--mono);width:140px;flex-shrink:0}
.audit-action{padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600;flex-shrink:0}
.audit-action.info{background:var(--bs);color:#93c5fd}.audit-action.warning{background:var(--os);color:#fbbf24}.audit-action.critical{background:var(--rs);color:var(--rt)}
.audit-detail{flex:1;color:var(--t2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.audit-user{font-size:11px;color:var(--t3);width:120px;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.powered-by{text-align:center;font-size:10px;color:var(--t4);padding:8px 0}
.msg-feedback{display:flex;gap:4px;padding:2px 4px;margin-top:2px}.msg-feedback button{padding:2px 6px;border-radius:4px;font-size:11px;color:var(--t4);transition:var(--tr);cursor:pointer;background:transparent;border:none}.msg-feedback button:hover{background:var(--sh);color:var(--t1)}.msg-feedback button.active-up{color:var(--green);background:var(--gs)}.msg-feedback button.active-down{color:var(--red);background:var(--rs)}
.tmpl-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px;transition:var(--tr)}.tmpl-card:hover{border-color:var(--bh);box-shadow:0 1px 2px rgba(0,0,0,.4)}
.tmpl-card-head{display:flex;align-items:center;gap:10px;margin-bottom:8px}.tmpl-card-icon{width:38px;height:38px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.tmpl-card-name{font-size:13px;font-weight:600;color:var(--t0)}.tmpl-card-cat{font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px}
.tmpl-card-desc{font-size:12px;color:var(--t3);margin-bottom:12px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.5}
.tmpl-card-foot{display:flex;align-items:center;justify-content:space-between;font-size:10px;color:var(--t4)}
.rec-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:10px}.rec-card-head{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.rec-card-name{font-size:13px;font-weight:600;color:var(--t0);flex:1}.rec-card-confidence{font-size:10px;font-family:var(--mono);padding:2px 8px;border-radius:4px;background:var(--bs);color:#93c5fd}
.rec-card-reason{font-size:12px;color:var(--t3);margin-bottom:10px}.rec-card-actions{display:flex;gap:8px}
.perf-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--bd)}.perf-icon{width:32px;height:32px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.perf-name{font-size:12px;font-weight:600;width:140px;color:var(--t1);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.perf-stat{font-size:11px;font-family:var(--mono);color:var(--t2);text-align:center;width:80px}
.perf-bar{width:80px;height:6px;background:var(--bg-0);border-radius:3px;overflow:hidden}.perf-bar-fill{height:100%;border-radius:3px}
.onboarding-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(6px);z-index:950;display:none;align-items:center;justify-content:center}.onboarding-overlay.active{display:flex}
.onboarding-box{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:32px;width:560px;max-height:85vh;overflow-y:auto;box-shadow:0 24px 64px rgba(0,0,0,.7)}
.onboarding-step{display:none}.onboarding-step.active{display:block}
.onboarding-header{text-align:center;margin-bottom:24px}.onboarding-header .icon{font-size:40px;margin-bottom:8px}.onboarding-header h2{font-size:20px;font-weight:700;color:var(--t0);margin-bottom:4px}.onboarding-header p{font-size:13px;color:var(--t3)}
.onboarding-progress{display:flex;gap:6px;justify-content:center;margin-bottom:24px}.onboarding-dot{width:8px;height:8px;border-radius:50%;background:var(--border);transition:var(--tr)}.onboarding-dot.active{background:var(--accent);width:24px;border-radius:4px}.onboarding-dot.done{background:var(--green)}
.onboarding-nav{display:flex;justify-content:space-between;margin-top:24px;padding-top:16px;border-top:1px solid var(--bd)}
.tmpl-pick{display:grid;grid-template-columns:1fr 1fr;gap:8px;max-height:240px;overflow-y:auto;padding:2px}
.tmpl-pick-item{display:flex;align-items:center;gap:8px;padding:8px 10px;border:1px solid var(--border);border-radius:6px;cursor:pointer;transition:var(--tr);font-size:12px}.tmpl-pick-item:hover{border-color:var(--bh)}.tmpl-pick-item.selected{border-color:var(--accent);background:var(--as)}
.tmpl-pick-icon{font-size:16px;flex-shrink:0}.tmpl-pick-name{font-weight:500;color:var(--t1)}.tmpl-pick-cat{font-size:10px;color:var(--t3)}
.help-btn{position:fixed;bottom:16px;right:16px;width:36px;height:36px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;cursor:pointer;box-shadow:0 2px 8px rgba(79,70,229,.3);z-index:800;transition:var(--tr)}.help-btn:hover{background:var(--ah);transform:scale(1.05)}
.help-panel{position:fixed;bottom:60px;right:16px;width:340px;max-height:480px;background:var(--surface);border:1px solid var(--border);border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.5);z-index:800;display:none;overflow:hidden}.help-panel.active{display:flex;flex-direction:column}
.help-panel-head{padding:14px 16px;border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between}.help-panel-head h3{font-size:14px;font-weight:700;color:var(--t0)}.help-panel-close{cursor:pointer;color:var(--t3);font-size:14px}
.help-panel-body{flex:1;overflow-y:auto;padding:12px 16px}
.help-section{margin-bottom:16px}.help-section h4{font-size:11px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
.help-item{display:flex;gap:8px;padding:6px 0;font-size:12px;color:var(--t2);align-items:flex-start}.help-item-icon{font-size:14px;flex-shrink:0;line-height:1.4}
.kbd{display:inline-flex;padding:2px 6px;background:var(--bg-2);border:1px solid var(--border);border-radius:4px;font-size:10px;font-family:var(--mono);color:var(--t2);line-height:1.4;white-space:nowrap}
.shortcut-row{display:flex;align-items:center;justify-content:space-between;padding:5px 0;font-size:12px;color:var(--t2)}.shortcut-keys{display:flex;gap:4px}
.tooltip{position:absolute;background:var(--bg-2);border:1px solid var(--border);border-radius:6px;padding:6px 10px;font-size:11px;color:var(--t1);box-shadow:0 4px 12px rgba(0,0,0,.4);z-index:700;max-width:220px;pointer-events:none;opacity:0;transition:opacity .15s}.tooltip.show{opacity:1}
.sidebar-head .logo-img{width:26px;height:26px;border-radius:7px;object-fit:cover}
.auth-logo .logo-img{width:36px;height:36px;border-radius:10px;object-fit:cover}
.welcome-msg{text-align:center;font-size:12px;color:var(--t3);margin-bottom:20px;line-height:1.5}
.spend-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:16px}
.spend-stat{background:var(--bg-2);border:1px solid var(--border);border-radius:8px;padding:14px;text-align:center}.spend-stat .value{font-size:20px;font-weight:700;color:var(--t0);font-family:var(--mono)}.spend-stat .label{font-size:10px;color:var(--t3);margin-top:2px;text-transform:uppercase;letter-spacing:.5px}
.spend-stat.warn .value{color:var(--orange)}.spend-stat.danger .value{color:var(--red)}
.spend-chart{background:var(--bg-2);border:1px solid var(--border);border-radius:8px;padding:14px;margin-bottom:12px}.spend-chart-title{font-size:12px;font-weight:600;color:var(--t1);margin-bottom:10px}
.spend-bars{display:flex;align-items:flex-end;gap:2px;height:100px;position:relative}.spend-bar{flex:1;background:var(--accent);border-radius:2px 2px 0 0;position:relative;min-width:4px;transition:var(--tr);cursor:crosshair}.spend-bar:hover{opacity:.8}.spend-bar-label{position:absolute;bottom:-16px;left:50%;transform:translateX(-50%);font-size:8px;color:var(--t4);white-space:nowrap}
.spend-table{width:100%;border-collapse:collapse;font-size:12px}.spend-table th{text-align:left;font-size:10px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;padding:6px 8px;border-bottom:1px solid var(--bd)}.spend-table td{padding:6px 8px;border-bottom:1px solid var(--bd);color:var(--t2)}.spend-table tr:hover td{background:var(--bg-1)}
.alert-banner{padding:8px 14px;border-radius:6px;font-size:12px;margin-bottom:8px}.alert-danger{background:#ef444420;border:1px solid #ef444444;color:#fca5a5}.alert-warning{background:#f59e0b20;border:1px solid #f59e0b44;color:#fcd34d}
.budget-mgmt{display:flex;flex-direction:column;gap:12px}.budget-row{display:flex;align-items:center;gap:12px;padding:10px 12px;background:var(--bg-1);border:1px solid var(--bd);border-radius:8px}
.budget-row-info{flex:1;min-width:0}.budget-row-scope{font-size:11px;font-weight:600;color:var(--t1)}.budget-row-detail{font-size:10px;color:var(--t3)}
.budget-row-bar{width:120px;height:6px;background:var(--bg-0);border-radius:3px;overflow:hidden}.budget-row-fill{height:100%;border-radius:3px;transition:.3s}
.budget-row-pct{font-family:var(--mono);font-size:11px;font-weight:600;min-width:40px;text-align:right}
.budget-form{display:grid;grid-template-columns:1fr 1fr 100px auto auto;gap:8px;align-items:end;padding:12px;background:var(--bg-1);border:1px solid var(--bd);border-radius:8px}
.usage-widget{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:12px}
.usage-card{padding:14px;background:var(--bg-1);border:1px solid var(--bd);border-radius:10px;text-align:center}
.usage-card .val{font-size:22px;font-weight:700;color:var(--t0);font-family:var(--mono)}.usage-card .lbl{font-size:10px;color:var(--t3);margin-top:2px}
.usage-card .sub{font-size:10px;color:var(--t3);margin-top:4px}
.spend-alert{padding:10px 16px;border-radius:8px;font-size:12px;display:flex;align-items:center;gap:8px;margin-bottom:8px}
.spend-alert.warn{background:#ca8a0414;border:1px solid #ca8a0433;color:#ca8a04}.spend-alert.danger{background:#dc262614;border:1px solid #dc262633;color:#dc2626}
.dept-budget-bar{margin-top:8px}.dept-budget-meta{display:flex;justify-content:space-between;font-size:9px;color:var(--t3);font-family:var(--mono);margin-top:3px}
.spend-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:16px}
.spend-stat{background:var(--bg-1);border:1px solid var(--border);border-radius:8px;padding:14px;text-align:center}
.spend-stat .value{font-size:22px;font-weight:700;color:var(--t0)}.spend-stat .label{font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-top:2px}
.spend-stat.warn .value{color:var(--orange)}.spend-stat.danger .value{color:var(--red)}
.spend-chart{background:var(--bg-1);border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:16px}
.spend-chart-title{font-size:12px;font-weight:600;color:var(--t2);margin-bottom:12px}
.spend-bars{display:flex;align-items:flex-end;gap:3px;height:100px}.spend-bar{flex:1;background:var(--accent);border-radius:2px 2px 0 0;min-width:4px;position:relative;transition:var(--tr)}.spend-bar:hover{opacity:.8}
.spend-bar-label{position:absolute;bottom:-16px;left:50%;transform:translateX(-50%);font-size:8px;color:var(--t3);white-space:nowrap}
.spend-table{width:100%;border-collapse:collapse;font-size:12px}.spend-table th{text-align:left;font-size:10px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;padding:6px 8px;border-bottom:1px solid var(--bd)}
.spend-table td{padding:6px 8px;border-bottom:1px solid var(--bd);color:var(--t2)}.spend-table tr:hover{background:var(--bg-1)}
.budget-badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600}.budget-ok{background:#16a34a22;color:#16a34a}.budget-warn{background:#ca8a0422;color:#ca8a04}.budget-exceed{background:#dc262622;color:#dc2626}
.alert-banner{display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:8px;font-size:12px;margin-bottom:12px}.alert-warning{background:#ca8a0412;border:1px solid #ca8a0444;color:#ca8a04}.alert-danger{background:#dc262612;border:1px solid #dc262644;color:#dc2626}
#toast-container{position:fixed;top:16px;right:16px;z-index:1000;display:flex;flex-direction:column;gap:8px}
.toast{padding:10px 16px;border-radius:6px;font-size:12px;font-weight:500;box-shadow:0 4px 12px rgba(0,0,0,.4);border:1px solid;max-width:320px;animation:ti .2s ease}
.toast.success{background:var(--gs);color:var(--gt);border-color:rgba(34,197,94,.2)}
.toast.error{background:var(--rs);color:var(--rt);border-color:rgba(239,68,68,.2)}
.toast.info{background:var(--bs);color:#93c5fd;border-color:rgba(59,130,246,.2)}
@keyframes ti{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:none}}
@media(max-width:1100px){.stats-grid{grid-template-columns:repeat(2,1fr)}.dash-grid{grid-template-columns:1fr}}
</style></head><body>
<div id="auth-screen"><div class="auth-box">
<div class="auth-logo"><div class="mark">M</div><div class="wordmark">MyTeam360</div></div>
<div class="auth-subtitle" id="auth-title">Sign in to your workspace</div>
<div id="login-form">
<div class="auth-field"><label>Email</label><input type="email" id="login-email" placeholder="you@company.com" onkeydown="if(event.key==='Enter')doLogin()"></div>
<div class="auth-field"><label>Password</label><input type="password" id="login-pass" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"></div>
<button class="auth-btn" onclick="doLogin()">Sign In</button>
<div class="auth-error" id="login-error"></div>
<div class="auth-switch">No account? <a onclick="showRegister()">Create one</a></div>
</div>
<div id="register-form" style="display:none">
<div class="auth-field"><label>Name</label><input id="reg-name" placeholder="Full name" onkeydown="if(event.key==='Enter')doRegister()"></div>
<div class="auth-field"><label>Email</label><input type="email" id="reg-email" placeholder="you@company.com" onkeydown="if(event.key==='Enter')doRegister()"></div>
<div class="auth-field"><label>Password</label><input type="password" id="reg-pass" placeholder="••••••••" onkeydown="if(event.key==='Enter')doRegister()"></div>
<button class="auth-btn" onclick="doRegister()">Create Account</button>
<div class="auth-error" id="reg-error"></div>
<div class="auth-switch">Have an account? <a onclick="showLogin()">Sign in</a></div>
</div>
</div></div>

<div id="app"><div class="sidebar">
<div class="sidebar-head"><div class="mark">M</div><div class="brand" id="brand-name">MyTeam360</div></div>
<div class="nav-group"><div class="nav-label">Workspace</div>
