# ═══════════════════════════════════════════════════
# MyTeam360 — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── Domain ──
APP_URL=https://myteam360.ai

# ── Server ──
PORT=8000
BIND_HOST=127.0.0.1
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
DEBUG=false

# ── Google OAuth ──
# Get these from: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://myteam360.ai/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI Providers (add any you want) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# ── Database ──
DB_PATH=/opt/myteam360/data/myteam360.db

# ── Security ──
SESSION_HOURS=24
# IP_WHITELIST=  # comma-separated, leave empty for no restriction

# ── Stripe Billing ──
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Create prices in Stripe Dashboard → Products → Add Product
# Monthly: $15/mo recurring  |  Annual: $129/yr recurring
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# Webhook secret from: Stripe Dashboard → Webhooks → Add endpoint
# URL: https://myteam360.ai/api/billing/webhook
# Events: checkout.session.completed, customer.subscription.updated,
#          customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=
