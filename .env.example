# ═══════════════════════════════════════════════════════════════
# MyTeam360 — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://mt360:YOUR_PASSWORD@localhost:5432/myteam360
# For local dev with SQLite (auto-creates file):
# DATABASE_URL=sqlite:///data/myteam360.db

# App secret key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_HEX

# Encryption key for AES-256-GCM (auto-generated on first run if not set)
# MT360_ENCRYPTION_KEY=

# ── EMAIL (choose one provider) ──────────────────────────────

# Option 1: SendGrid
# SENDGRID_API_KEY=SG.xxxxx

# Option 2: SMTP (Gmail, Outlook, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password

# Option 3: Mailgun
# MAILGUN_API_KEY=key-xxxxx
# MAILGUN_DOMAIN=mg.myteam360.ai

# Sender
EMAIL_FROM=noreply@myteam360.ai
EMAIL_FROM_NAME=MyTeam360

# ── PAYMENTS ─────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# For testing:
# STRIPE_SECRET_KEY=sk_test_xxxxx

# ── OAUTH (optional) ────────────────────────────────────────

# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# ── DEPLOYMENT ───────────────────────────────────────────────

FLASK_ENV=production
BASE_URL=https://myteam360.ai

# CORS (comma-separated origins, leave empty for same-origin only)
# CORS_ORIGINS=https://myteam360.ai,https://www.myteam360.ai

# ── OPTIONAL ─────────────────────────────────────────────────

# PostgreSQL connection pool
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# Postgres password (for docker-compose)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
